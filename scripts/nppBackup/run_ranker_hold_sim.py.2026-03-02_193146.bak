# scripts/run_ranker_hold_sim.py
# Double-click runnable. Never auto-closes.
#
# Long-only cross-sectional ranker + hold simulator (close-to-close).
# Additions:
#  - Rolling entry cap per symbol (window days)
#  - Per-day cluster caps for picks
#  - Anti-frequency score penalty
#  - Cash floor + cash_pct clamp (no "-0.00%")
#
from __future__ import annotations

import os
import sys
import math
import traceback
from dataclasses import dataclass
from pathlib import Path
from typing import Dict, List, Tuple, Set, Deque
from collections import deque, defaultdict

import numpy as np
import pandas as pd


def _press_enter_exit(code: int) -> None:
    try:
        print(f"\n[EXIT] code={code}")
        input("Press Enter to exit...")
    except Exception:
        pass
    raise SystemExit(code)


def _add_src_to_syspath() -> None:
    root = Path(__file__).resolve().parents[1]
    src = root / "src"
    if src.exists():
        sys.path.insert(0, str(src))


def _env_str(name: str, default: str = "") -> str:
    v = os.environ.get(name, default)
    return (v if v is not None else default).strip()


def _env_int(name: str, default: int) -> int:
    v = os.environ.get(name)
    if v is None or not str(v).strip():
        return default
    try:
        return int(float(str(v).strip()))
    except Exception:
        return default


def _env_float(name: str, default: float) -> float:
    v = os.environ.get(name)
    if v is None or not str(v).strip():
        return default
    try:
        return float(str(v).strip())
    except Exception:
        return default


def _fmt(x: float, nd: int = 4) -> str:
    if x != x:
        return "nan"
    return f"{x:.{nd}f}"


def _fmt_pct(x: float) -> str:
    if x != x:
        return "nan"
    return f"{x*100:.2f}%"


def _load_universe(root: Path) -> List[str]:
    p = root / "data" / "universe_etf_first_30.txt"
    txt = p.read_text(encoding="utf-8", errors="ignore")
    out = []
    for line in txt.splitlines():
        s = line.strip()
        if not s or s.startswith("#"):
            continue
        out.append(s.upper())
    return out


def _make_folds(dates: List[str], train_days: int, test_days: int, purge_days: int, max_folds: int = 6) -> List[Tuple[int, int, int, int, int]]:
    folds: List[Tuple[int, int, int, int, int]] = []
    t_end = train_days
    fid = 0
    step = test_days
    while True:
        train_end = t_end
        test_start = train_end + purge_days
        test_end = test_start + test_days
        train_start = max(0, train_end - train_days)
        if test_end > len(dates):
            break
        fid += 1
        folds.append((fid, train_start, train_end, test_start, test_end))
        t_end += step
        if fid >= max_folds:
            break
    return folds


def _weight_from_metrics(avg_lift: float, fold_count: int, avg_es5: float, oos_lift_min: float) -> float:
    edge = max(0.0, avg_lift - oos_lift_min)
    stability = 1.25 if fold_count >= 3 else 1.0
    tail_pen = max(0.0, (-avg_es5) - 0.10)  # penalize ES worse than -10%
    return float(stability * edge / (1.0 + 5.0 * tail_pen))


def _max_drawdown(equity: np.ndarray) -> float:
    peak = np.maximum.accumulate(equity)
    dd = equity / np.maximum(1e-12, peak) - 1.0
    return float(np.min(dd))


def _sharpe(daily_ret: np.ndarray) -> float:
    if daily_ret.size < 2:
        return float("nan")
    mu = float(np.mean(daily_ret))
    sd = float(np.std(daily_ret, ddof=1))
    if sd <= 1e-12:
        return float("nan")
    return float((mu / sd) * math.sqrt(252.0))


def _cagr(equity_start: float, equity_end: float, n_days: int) -> float:
    years = n_days / 252.0
    if years <= 0 or equity_start <= 0:
        return float("nan")
    return float((equity_end / equity_start) ** (1.0 / years) - 1.0)


@dataclass
class Position:
    symbol: str
    entry_day_index: int
    entry_date: str
    entry_px: float
    shares: float
    age: int = 0


# ----------------------------
# Cluster logic
# ----------------------------
VOL_FEATS = {"atr_pct", "rv_10", "compression"}
MOM_FEATS = {"mom_1d", "mom_3d", "mom_5d", "mom_10d", "mom_20d"}
TREND_FEATS = {"ema_dist", "ema_fast_slope", "ema_slow_slope"}


def _sig_features(signature: str) -> Set[str]:
    parts = signature.split("|")
    feats: Set[str] = set()
    for p in parts[1:]:
        for op in (">", "<"):
            if op in p:
                feats.add(p.split(op)[0])
                break
    return feats


def _clusters_for_feats(feats: Set[str]) -> Set[str]:
    out = set()
    if feats & VOL_FEATS:
        out.add("VOL")
    if feats & MOM_FEATS:
        out.add("MOM")
    if feats & TREND_FEATS:
        out.add("TREND")
    if not out:
        out.add("OTHER")
    return out


def _dominant_cluster_from_feats(feats: Set[str]) -> str:
    # priority ordering: PAIR > VOL > MOM > TREND > OTHER
    has_pair = ("atr_pct" in feats) and ("rv_10" in feats)
    if has_pair:
        return "PAIR"
    if feats & VOL_FEATS:
        return "VOL"
    if feats & MOM_FEATS:
        return "MOM"
    if feats & TREND_FEATS:
        return "TREND"
    return "OTHER"


def select_runtime_with_cluster_caps(
    df_lib: pd.DataFrame,
    topn: int,
    cap_vol: int,
    cap_mom: int,
    cap_trend: int,
    cap_other: int,
    cap_pair: int,
) -> Tuple[pd.DataFrame, Dict[str, int]]:
    counts = {"VOL": 0, "MOM": 0, "TREND": 0, "OTHER": 0, "PAIR": 0, "SKIP": 0}
    selected = []

    for _, r in df_lib.iterrows():
        if len(selected) >= topn:
            break

        sig = str(r["signature"])
        feats = _sig_features(sig)
        dom = _dominant_cluster_from_feats(feats)

        if dom == "PAIR" and counts["PAIR"] >= cap_pair:
            counts["SKIP"] += 1
            continue
        if dom == "VOL" and counts["VOL"] >= cap_vol:
            counts["SKIP"] += 1
            continue
        if dom == "MOM" and counts["MOM"] >= cap_mom:
            counts["SKIP"] += 1
            continue
        if dom == "TREND" and counts["TREND"] >= cap_trend:
            counts["SKIP"] += 1
            continue
        if dom == "OTHER" and counts["OTHER"] >= cap_other:
            counts["SKIP"] += 1
            continue

        selected.append(r)
        counts[dom] += 1

    out = pd.DataFrame(selected).reset_index(drop=True)
    return out, counts


def main() -> int:
    _add_src_to_syspath()

    from python_edge.data.ingest_aggs import load_aggs, to_daily_index
    from python_edge.features.build_features_daily import DailyFeatureConfig, build_daily_features
    from python_edge.rules.event_mining import EventMiningConfig, label_events, mine_event_rules, evaluate_rules_oos

    root = Path(__file__).resolve().parents[1]

    start = _env_str("DATA_START", "")
    end = _env_str("DATA_END", "")
    if not start or not end:
        raise RuntimeError("Missing DATA_START/DATA_END. Example: 2023-01-01 / 2026-02-28")

    dataset_root = Path(_env_str("DATA_OUT_DIR", str(root / "data" / "raw" / "massive_dataset")))
    tickers = _load_universe(root)

    hold_days = _env_int("HOLD_DAYS", 5)
    max_pos = _env_int("MAX_POS", 3)

    entry_bps = _env_float("TC_ENTRY_BPS", 4.0)
    exit_bps = _env_float("TC_EXIT_BPS", 4.0)
    entry_rate = entry_bps / 10000.0
    exit_rate = exit_bps / 10000.0

    oos_lift_min = _env_float("LAB_OOS_LIFT_MIN", 1.35)
    topn_long = _env_int("RUNTIME_TOPN_LONG", 40)

    # ---- Rolling entry cap (per symbol) ----
    rolling_cap_days = _env_int("ROLLING_ENTRY_CAP_DAYS", 60)
    rolling_cap_max = _env_int("MAX_ENTRIES_PER_SYMBOL_IN_WINDOW", 6)

    # ---- Anti-frequency penalty ----
    freq_lookback = _env_int("FREQ_LOOKBACK_DAYS", 20)
    freq_lambda = _env_float("FREQ_LAMBDA", 0.50)  # 0..1

    # ---- Cluster caps for daily picks ----
    max_pick_pair = _env_int("MAX_PICKS_PAIR", 1)
    max_pick_vol = _env_int("MAX_PICKS_VOL", 1)
    max_pick_mom = _env_int("MAX_PICKS_MOM", 1)
    max_pick_trend = _env_int("MAX_PICKS_TREND", 1)
    max_pick_other = _env_int("MAX_PICKS_OTHER", 3)

    # ---- Library cluster caps ----
    cap_vol = _env_int("CAP_VOL", 20)
    cap_mom = _env_int("CAP_MOM", 18)
    cap_trend = _env_int("CAP_TREND", 16)
    cap_other = _env_int("CAP_OTHER", 40)
    cap_pair = _env_int("CAP_PAIR", 6)

    # ---- Walk-forward ----
    train_days = _env_int("WF_TRAIN_DAYS", 420)
    test_days = _env_int("WF_TEST_DAYS", 90)
    purge_days = _env_int("WF_PURGE_DAYS", 10)
    max_folds = _env_int("WF_MAX_FOLDS", 6)

    # ---- Rebalance-lite ----
    rebalance = (_env_int("REBALANCE", 1) == 1)
    rebalance_band = _env_float("REBALANCE_BAND", 0.10)

    # ---- Cash: eps + floor + clamp ----
    cash_eps_pct = _env_float("CASH_EPS_PCT", 0.005)  # 0.5% equity default
    cash_eps_abs = _env_float("CASH_EPS_ABS", 1e-6)
    cash_floor_eps = _env_float("CASH_FLOOR_EPS", 1e-9)

    cfg = EventMiningConfig(
        fwd_days=_env_int("LAB_FWD_DAYS", 5),
        k_sigma=_env_float("LAB_K_SIGMA", 1.5),
        max_rules_try=_env_int("LAB_MAX_RULES_TRY", 6000),
        max_rules_keep=_env_int("LAB_MAX_RULES_KEEP", 800),
        min_support=_env_int("LAB_MIN_SUPPORT", 200),
        min_event_hits=_env_int("LAB_MIN_EVENT_HITS", 30),
        max_conds=_env_int("LAB_MAX_CONDS", 3),
        seed=_env_int("LAB_SEED", 7),
        perm_trials=_env_int("LAB_PERM_TRIALS", 50),
        perm_topk=_env_int("LAB_PERM_TOPK", 20),
        perm_gate_enabled=(_env_int("LAB_PERM_GATE", 1) == 1),
        perm_gate_margin=_env_float("LAB_PERM_GATE_MARGIN", 0.15),
    )

    print(f"[CFG] hold_days={hold_days} max_pos={max_pos} TC(in/out)={entry_bps:.1f}/{exit_bps:.1f} bps")
    print(f"[CFG] rolling entry cap: days={rolling_cap_days} max={rolling_cap_max}")
    print(f"[CFG] anti-freq: lookback={freq_lookback} lambda={freq_lambda}")
    print(f"[CFG] pick cluster caps: PAIR={max_pick_pair} VOL={max_pick_vol} MOM={max_pick_mom} TREND={max_pick_trend} OTHER={max_pick_other}")
    print(f"[CFG] library caps: VOL={cap_vol} MOM={cap_mom} TREND={cap_trend} OTHER={cap_other} PAIR={cap_pair}")
    print(f"[CFG] rebalance: enabled={rebalance} band={rebalance_band}")
    print(f"[CFG] cash_eps: pct={cash_eps_pct} abs={cash_eps_abs} cash_floor_eps={cash_floor_eps}")
    print(f"[CFG] event: fwd_days={cfg.fwd_days} k_sigma={cfg.k_sigma} sigma_lookback={cfg.sigma_lookback}")
    print(f"[CFG] rules: try={cfg.max_rules_try} keep={cfg.max_rules_keep} min_support={cfg.min_support} min_event_hits={cfg.min_event_hits}")
    print(f"[CFG] perm: trials={cfg.perm_trials} topk={cfg.perm_topk} gate={cfg.perm_gate_enabled} margin={cfg.perm_gate_margin}")
    print(f"[CFG] OOS filter: support>={cfg.min_support} lift>={oos_lift_min}")
    print(f"[CFG] runtime_topn_long={topn_long}")

    # ----------------------------
    # Load daily + features
    # ----------------------------
    panels = []
    for t in tickers:
        r = load_aggs(dataset_root=dataset_root, symbol=t, tf="1d", start=start, end=end, prefer_full=True)
        df = to_daily_index(r.df)
        if df.empty:
            continue
        df = df[["date", "o", "h", "l", "c", "v"]].copy()
        df["symbol"] = t
        df = build_daily_features(df, DailyFeatureConfig(fwd_days=cfg.fwd_days))
        panels.append(df)
    if not panels:
        raise RuntimeError("No data loaded.")

    all_df = pd.concat(panels, ignore_index=True).sort_values(["date", "symbol"]).reset_index(drop=True)
    all_df = label_events(all_df, cfg)

    feature_cols = [
        "mom_1d", "mom_3d", "mom_5d", "mom_10d", "mom_20d",
        "ema_dist", "ema_fast_slope", "ema_slow_slope",
        "atr_pct", "rv_10", "compression",
    ]
    feature_cols = [c for c in feature_cols if c in all_df.columns]
    need = feature_cols + [f"fwd_{cfg.fwd_days}d_ret", "ret_1d", "event_up", "event_dn", "event_thr", "c"]
    all_df = all_df.dropna(subset=need).copy()

    print(f"[DATA] pooled rows={len(all_df)} dates={all_df['date'].nunique()} symbols={all_df['symbol'].nunique()}")
    print(f"[DATA] base_rate up={float(all_df['event_up'].mean()):.4%} dn={float(all_df['event_dn'].mean()):.4%}")

    dates = sorted(all_df["date"].unique().tolist())
    folds = _make_folds(dates, train_days=train_days, test_days=test_days, purge_days=purge_days, max_folds=max_folds)
    if not folds:
        raise RuntimeError("No folds produced.")

    # ----------------------------
    # Build OOS-filtered library
    # ----------------------------
    lib: Dict[str, Dict[str, object]] = {}
    per_fold_counts: List[Tuple[int, int, int]] = []

    def _acc(sig: str, row: pd.Series, fold_id: int) -> None:
        d = lib.get(sig)
        if d is None:
            d = {"signature": sig, "folds": set(), "n": 0,
                 "sum_support": 0.0, "sum_lift": 0.0,
                 "sum_mean": 0.0, "sum_median": 0.0, "sum_ppos": 0.0, "sum_es5": 0.0}
            lib[sig] = d
        d["folds"].add(fold_id)
        d["n"] += 1
        d["sum_support"] += float(row["support"])
        d["sum_lift"] += float(row["lift"])
        d["sum_mean"] += float(row["mean_signed"])
        d["sum_median"] += float(row["median_signed"])
        d["sum_ppos"] += float(row["p_pos_signed"])
        d["sum_es5"] += float(row["es5_signed"])

    for (fold_id, i0, i1, j0, j1) in folds:
        tr_dates = dates[i0:i1]
        te_dates = dates[j0:j1]
        df_tr = all_df[all_df["date"].isin(tr_dates)].copy()
        df_te = all_df[all_df["date"].isin(te_dates)].copy()

        print("\n" + "=" * 80)
        print(f"[LIB/FOLD {fold_id}] train={tr_dates[0]}..{tr_dates[-1]}  test={te_dates[0]}..{te_dates[-1]}")
        rules, _, perm = mine_event_rules(df_tr, feature_cols, cfg)
        print(f"[LIB/FOLD {fold_id}] mined_rules={len(rules)} perm_p95={float(perm.get('perm_topk_p95', float('nan'))):.3f}")
        if not rules:
            per_fold_counts.append((fold_id, 0, 0))
            continue

        oos = evaluate_rules_oos(df_te, rules, cfg)
        if oos.empty:
            per_fold_counts.append((fold_id, 0, 0))
            continue

        oos = oos[oos["direction"] == "long"].copy()
        big_eval = int((oos["support"] >= cfg.min_support).sum())
        oos_f = oos[(oos["support"] >= cfg.min_support) & (oos["lift"].fillna(0.0) >= oos_lift_min)].copy()
        passed = int(len(oos_f))
        per_fold_counts.append((fold_id, big_eval, passed))
        print(f"[LIB/FOLD {fold_id}] OOS long big-eval={big_eval} pass(lift>={oos_lift_min})={passed}")

        for _, r in oos_f.iterrows():
            _acc(str(r["signature"]), r, fold_id)

    print("\n" + "=" * 80)
    print("[GLOBAL] Long Rule Library (OOS-filtered across folds)")
    print("[GLOBAL] Fold pass counts: " + " | ".join([f"F{fid}: {p}/{e}" for (fid, e, p) in per_fold_counts]))

    if not lib:
        print("[GLOBAL] No long rules passed.")
        return 0

    rows = []
    for sig, d in lib.items():
        n = int(d["n"])
        folds_set: Set[int] = d["folds"]
        fold_count = len(folds_set)
        rows.append({
            "signature": sig,
            "fold_count": fold_count,
            "avg_support": float(d["sum_support"]) / n,
            "avg_lift": float(d["sum_lift"]) / n,
            "avg_mean": float(d["sum_mean"]) / n,
            "avg_median": float(d["sum_median"]) / n,
            "avg_p_pos": float(d["sum_ppos"]) / n,
            "avg_es5": float(d["sum_es5"]) / n,
            "folds": ",".join([str(x) for x in sorted(list(folds_set))]),
        })

    df_lib = pd.DataFrame(rows)
    df_lib = df_lib[df_lib["fold_count"] >= 2].copy()
    if df_lib.empty:
        print("[GLOBAL] None appear in >=2 folds.")
        return 0

    df_lib["weight"] = df_lib.apply(
        lambda r: _weight_from_metrics(float(r["avg_lift"]), int(r["fold_count"]), float(r["avg_es5"]), oos_lift_min),
        axis=1
    )
    df_lib = df_lib.sort_values(["fold_count", "weight", "avg_lift"], ascending=[False, False, False]).reset_index(drop=True)

    print(f"[GLOBAL] library_size={len(df_lib)} (long, fold_count>=2)")

    runtime, caps = select_runtime_with_cluster_caps(
        df_lib=df_lib,
        topn=topn_long,
        cap_vol=cap_vol,
        cap_mom=cap_mom,
        cap_trend=cap_trend,
        cap_other=cap_other,
        cap_pair=cap_pair,
    )
    runtime_sigs = runtime["signature"].tolist()
    w_by_sig = {str(r["signature"]): float(r["weight"]) for _, r in runtime.iterrows()}
    dom_cluster_by_sig = {sig: _dominant_cluster_from_feats(_sig_features(sig)) for sig in runtime_sigs}

    print(f"[RUNTIME] selected signatures={len(runtime_sigs)}/{topn_long} caps={caps}")
    if len(runtime_sigs) == 0:
        print("[RUNTIME] empty after caps (loosen CAP_*).")
        return 0

    # ----------------------------
    # Simulate per fold OOS
    # ----------------------------
    for (fold_id, i0, i1, j0, j1) in folds:
        te_dates = dates[j0:j1]
        df_tr = all_df[all_df["date"].isin(dates[i0:i1])].copy()
        df_te = all_df[all_df["date"].isin(te_dates)].copy()

        print("\n" + "=" * 80)
        print(f"[SIM/FOLD {fold_id}] OOS window={te_dates[0]}..{te_dates[-1]} rows={len(df_te)}")

        rules, _, _ = mine_event_rules(df_tr, feature_cols, cfg)
        if not rules or df_te.empty:
            print(f"[SIM/FOLD {fold_id}] skip.")
            continue

        # fold_rules: only those we kept in runtime
        fold_rules: List[Tuple[object, float, str]] = []  # (rule_obj, weight, signature)
        for r in rules:
            if r.direction != "long":
                continue
            parts = []
            for feat, op, meta_key in r.conds:
                tag = meta_key.split("__")[-1] if "__" in meta_key else meta_key
                parts.append(f"{feat}{op}{tag}")
            sig = r.direction + "|" + "|".join(sorted(parts))
            if sig in w_by_sig:
                w = float(w_by_sig[sig])
                if w > 0:
                    fold_rules.append((r, w, sig))
        print(f"[SIM/FOLD {fold_id}] fold_rules kept (long)={len(fold_rules)}")

        # Score arrays
        score = np.zeros(len(df_te), dtype=float)

        # Cluster contribution arrays -> dominant cluster per row
        cl_names = ["PAIR", "VOL", "MOM", "TREND", "OTHER"]
        cl_score = {c: np.zeros(len(df_te), dtype=float) for c in cl_names}

        def _apply_mask(rule_obj) -> np.ndarray:
            mask = np.ones(len(df_te), dtype=bool)
            for feat, op, meta_key in rule_obj.conds:
                thr = rule_obj.meta[meta_key]
                col = df_te[feat].to_numpy(dtype=float)
                if op == ">":
                    mask &= (col > thr)
                else:
                    mask &= (col < thr)
            return mask

        fires_total = 0
        for r, w, sig in fold_rules:
            m = _apply_mask(r)
            nm = int(np.sum(m))
            fires_total += nm
            if nm > 0:
                score[m] += w
                dom = dom_cluster_by_sig.get(sig, "OTHER")
                cl_score[dom][m] += w

        # dominant cluster per row
        cl_mat = np.vstack([cl_score[c] for c in cl_names])  # (5, n)
        cl_idx = np.argmax(cl_mat, axis=0)
        dom_cluster_row = np.array([cl_names[i] for i in cl_idx], dtype=object)

        out = df_te[["date", "symbol", "c"]].copy()
        out["score_long"] = score
        out["dom_cluster"] = dom_cluster_row

        day_cov = out.assign(pos=(out["score_long"] > 0).astype(int)).groupby("date")["pos"].mean()
        print(f"[SIM/FOLD {fold_id}] scored_rows(score>0)={int((out['score_long']>0).sum())}/{len(out)} fires_total={fires_total}")
        print(f"[SIM/FOLD {fold_id}] coverage per-day: mean={_fmt_pct(float(day_cov.mean()))} p10={_fmt_pct(float(day_cov.quantile(0.10)))} p90={_fmt_pct(float(day_cov.quantile(0.90)))}")

        # maps by day
        price: Dict[str, Dict[str, float]] = {}
        sc: Dict[str, Dict[str, float]] = {}
        cl: Dict[str, Dict[str, str]] = {}
        for d, g in out.groupby("date", sort=True):
            dd = str(d)
            price[dd] = {str(r.symbol): float(r.c) for r in g.itertuples(index=False)}
            sc[dd] = {str(r.symbol): float(r.score_long) for r in g.itertuples(index=False)}
            cl[dd] = {str(r.symbol): str(r.dom_cluster) for r in g.itertuples(index=False)}

        oos_days = te_dates[:]
        day_index = {d: i for i, d in enumerate(oos_days)}

        equity0 = 1.0
        cash = equity0
        positions: Dict[str, Position] = {}

        # rolling cap: store entry indices per symbol
        entry_hist: Dict[str, Deque[int]] = defaultdict(deque)

        # anti-frequency: track picks in last N days
        pick_hist_days: Deque[List[str]] = deque()  # each day list of picked symbols
        pick_count: Dict[str, int] = defaultdict(int)

        def _update_pick_history(picks_today: List[str]) -> None:
            # append
            pick_hist_days.append(picks_today)
            for s in picks_today:
                pick_count[s] += 1
            # evict old
            while len(pick_hist_days) > freq_lookback:
                old = pick_hist_days.popleft()
                for s in old:
                    pick_count[s] -= 1
                    if pick_count[s] <= 0:
                        del pick_count[s]

        # rebalance helper
        def _mtm_equity(day: str) -> float:
            eq = cash
            pmap = price.get(day, {})
            for sym, pos in positions.items():
                px = float(pmap.get(sym, pos.entry_px))
                eq += pos.shares * px
            return float(eq)

        def _cash_post_check() -> None:
            nonlocal cash
            if cash < 0 and cash > -cash_floor_eps:
                cash = 0.0
            elif cash < -cash_floor_eps:
                raise RuntimeError(f"Negative cash beyond eps: cash={cash}")

        def _rebalance_lite(day: str) -> None:
            nonlocal cash, tc_paid
            if not rebalance or not positions:
                return
            pmap = price.get(day, {})
            eq = _mtm_equity(day)
            target = eq / float(max_pos)

            for sym, pos in list(positions.items()):
                px = float(pmap.get(sym, pos.entry_px))
                notional = pos.shares * px
                if notional > target * (1.0 + rebalance_band):
                    sell_notional = notional - target
                    if sell_notional <= 0:
                        continue
                    sell_shares = sell_notional / px
                    if sell_shares >= pos.shares:
                        continue
                    proceeds = sell_shares * px
                    cost = exit_rate * proceeds
                    pos.shares -= sell_shares
                    cash += proceeds - cost
                    tc_paid += cost
                    _cash_post_check()

        # metrics
        eq_curve: List[float] = []
        pos_count_curve: List[int] = []
        cash_pct_curve: List[float] = []

        entries = 0
        exits = 0
        tc_paid = 0.0
        no_candidate_days = 0
        open_fail_days = 0
        cand_missing_px = 0
        cash_low_days = 0

        # A: debug counters
        dbg_skip_rollingcap = 0
        dbg_skip_cluster_cap = 0
        dbg_skip_low_score = 0

        for day in oos_days:
            di = day_index[day]
            pmap = price.get(day, {})

            # exit aged
            to_close = [sym for sym, pos in positions.items() if pos.age >= hold_days]
            for sym in to_close:
                pos = positions[sym]
                exit_px = float(pmap.get(sym, pos.entry_px))
                notional_exit = pos.shares * exit_px
                cost = exit_rate * notional_exit
                cash += notional_exit - cost
                tc_paid += cost
                exits += 1
                del positions[sym]
                _cash_post_check()

            for pos in positions.values():
                pos.age += 1

            slots = max_pos - len(positions)

            # if slots and cash ~ 0, try rebalance
            eq_now = _mtm_equity(day)
            cash_eps = max(cash_eps_abs, eq_now * cash_eps_pct)
            if slots > 0 and cash <= cash_eps:
                cash_low_days += 1
                _rebalance_lite(day)

            picks_today: List[str] = []

            if slots > 0:
                smap = sc.get(day, {})
                cmap = cl.get(day, {})

                # prepare candidates: (sym, score_adj, px, dom_cluster)
                cand = []
                for sym, s in smap.items():
                    if s <= 0:
                        continue
                    if sym in positions:
                        continue
                    px = float(pmap.get(sym, float("nan")))
                    if not np.isfinite(px) or px <= 0:
                        cand_missing_px += 1
                        continue

                    # rolling entry cap: purge old and check
                    h = entry_hist[sym]
                    while h and (di - h[0]) >= rolling_cap_days:
                        h.popleft()
                    if len(h) >= rolling_cap_max:
                        dbg_skip_rollingcap += 1
                        continue

                    # anti-frequency penalty
                    freq = float(pick_count.get(sym, 0))
                    freq_ratio = min(1.0, freq / max(1.0, float(freq_lookback)))
                    penalty = max(0.0, 1.0 - freq_lambda * freq_ratio)
                    s_adj = float(s) * penalty

                    if s_adj <= 0:
                        dbg_skip_low_score += 1
                        continue

                    domc = str(cmap.get(sym, "OTHER"))
                    cand.append((sym, s_adj, px, domc))

                cand.sort(key=lambda x: x[1], reverse=True)

                if not cand:
                    no_candidate_days += 1
                else:
                    # per-day cluster caps selection
                    cap_by_c = {
                        "PAIR": max_pick_pair,
                        "VOL": max_pick_vol,
                        "MOM": max_pick_mom,
                        "TREND": max_pick_trend,
                        "OTHER": max_pick_other,
                    }
                    used_by_c = {k: 0 for k in cap_by_c.keys()}

                    opens = []
                    for sym, s_adj, px, domc in cand:
                        if len(opens) >= slots:
                            break
                        if used_by_c.get(domc, 0) >= cap_by_c.get(domc, 0):
                            dbg_skip_cluster_cap += 1
                            continue
                        opens.append((sym, s_adj, px, domc))
                        used_by_c[domc] = used_by_c.get(domc, 0) + 1

                    if not opens:
                        open_fail_days += 1
                    else:
                        did_open = 0
                        for sym, s_adj, px, domc in opens:
                            remaining_opens = max(1, (len(opens) - did_open))
                            budget_each = cash / float(remaining_opens)

                            if budget_each <= cash_eps:
                                # practically no cash: skip silently (should be rare now)
                                continue

                            notional = budget_each / (1.0 + entry_rate)
                            cost = entry_rate * notional
                            total = notional + cost
                            if total <= 0:
                                continue
                            if total > cash + 1e-12:
                                continue

                            shares = notional / px
                            cash -= total
                            tc_paid += cost
                            _cash_post_check()

                            positions[sym] = Position(symbol=sym, entry_day_index=di, entry_date=day, entry_px=px, shares=shares, age=0)
                            entries += 1
                            did_open += 1
                            picks_today.append(sym)

                            # update rolling entry history
                            entry_hist[sym].append(di)

                            if did_open >= slots:
                                break

                        if did_open == 0:
                            open_fail_days += 1

            # update anti-frequency history with actual picks
            _update_pick_history(picks_today)

            eq = _mtm_equity(day)
            eq_curve.append(eq)
            pos_count_curve.append(len(positions))

            # clamp for reporting
            cash_pct_curve.append(float(max(0.0, cash) / max(1e-12, eq)))

        eq_arr = np.array(eq_curve, dtype=float)
        rets = (eq_arr[1:] / np.maximum(1e-12, eq_arr[:-1]) - 1.0) if eq_arr.size >= 2 else np.array([], dtype=float)

        end_eq = float(eq_arr[-1])
        cagr = _cagr(equity0, end_eq, n_days=len(eq_arr))
        mdd = _max_drawdown(eq_arr)
        sh = _sharpe(rets)

        avg_pos = float(np.mean(pos_count_curve)) if pos_count_curve else 0.0
        slot_fill = float(avg_pos / max(1, max_pos))
        turnover = float(entries / max(1, len(eq_arr)))

        cash_pct = np.array(cash_pct_curve, dtype=float) if cash_pct_curve else np.array([], dtype=float)
        avg_cash_pct = float(np.mean(cash_pct)) if cash_pct.size else float("nan")
        p10_cash_pct = float(np.quantile(cash_pct, 0.10)) if cash_pct.size else float("nan")

        # concentration by entries (simple)
        entry_counts = {k: len(v) for k, v in entry_hist.items() if len(v) > 0}
        top_sym = None
        top_sym_n = 0
        if entry_counts:
            top_sym, top_sym_n = sorted(entry_counts.items(), key=lambda x: x[1], reverse=True)[0]

        print(f"\n[SIM/FOLD {fold_id}] RESULTS (long-only, close-to-close)")
        print(f"[SIM/FOLD {fold_id}] equity_end={_fmt(end_eq,4)}  CAGR~={_fmt_pct(cagr)}  Sharpe~={_fmt(sh,2)}  MaxDD={_fmt_pct(mdd)}")
        print(f"[SIM/FOLD {fold_id}] entries={entries} exits={exits} turnover(entries/day)={_fmt(turnover,3)}  TC_paid={_fmt(tc_paid,4)}")
        print(f"[SIM/FOLD {fold_id}] avg_pos={_fmt(avg_pos,2)}/{max_pos} slot_fill={_fmt_pct(slot_fill)} no_candidate_days={no_candidate_days}/{len(eq_arr)} open_fail_days={open_fail_days}/{len(eq_arr)}")
        print(f"[SIM/FOLD {fold_id}] QA cand_missing_px_skips={cand_missing_px} cash_low_days={cash_low_days}/{len(eq_arr)} avg_cash_pct={_fmt_pct(avg_cash_pct)} p10_cash_pct={_fmt_pct(p10_cash_pct)}")
        print(f"[SIM/FOLD {fold_id}] DBG skips: rolling_cap={dbg_skip_rollingcap} cluster_cap={dbg_skip_cluster_cap} low_score={dbg_skip_low_score}")
        if top_sym is not None:
            print(f"[SIM/FOLD {fold_id}] concentration: top_symbol={top_sym} entries={top_sym_n} share_of_entries={_fmt_pct(top_sym_n/max(1,entries))}")

    print("\n[DONE] Ranker hold-sim MVP completed.")
    return 0


if __name__ == "__main__":
    try:
        rc = main()
    except Exception:
        traceback.print_exc()
        rc = 1
    _press_enter_exit(int(rc))
