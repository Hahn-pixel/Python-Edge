# scripts/run_ranker_hold_sim.py
# Double-click runnable. Never auto-closes.
# Massive (massive.com) dataset: daily aggs JSON. Long-only ranker MVP + time-slice survival + rolling signature health retire.

from __future__ import annotations

import os
import sys
import json
import math
import time
import traceback
from dataclasses import dataclass
from datetime import datetime, timezone, date, timedelta
from pathlib import Path
from typing import Any, Dict, Iterable, List, Optional, Tuple
from collections import defaultdict, deque

import pandas as pd


# ----------------------------- UX / Exit -----------------------------

def _press_enter_exit(code: int) -> None:
    try:
        print(f"\n[EXIT] code={code}")
        input("Press Enter to exit...")
    except Exception:
        pass
    raise SystemExit(code)


def _log(msg: str) -> None:
    ts = datetime.now().strftime("%H:%M:%S")
    print(f"[{ts}] {msg}", flush=True)


def _utc_now() -> str:
    return datetime.now(timezone.utc).isoformat()


def _env_str(name: str, default: str = "") -> str:
    v = os.environ.get(name, default)
    return (v if v is not None else default).strip()


def _env_int(name: str, default: int) -> int:
    v = os.environ.get(name)
    if v is None or not str(v).strip():
        return default
    try:
        return int(float(str(v).strip()))
    except Exception:
        return default


def _env_float(name: str, default: float) -> float:
    v = os.environ.get(name)
    if v is None or not str(v).strip():
        return default
    try:
        return float(str(v).strip())
    except Exception:
        return default


def _env_bool(name: str, default: bool = False) -> bool:
    v = os.environ.get(name)
    if v is None:
        return default
    s = str(v).strip().lower()
    return s in ("1", "true", "yes", "y", "on")


# ----------------------------- Config -----------------------------

@dataclass(frozen=True)
class Config:
    # data
    dataset_root: Path
    start: str
    end: str
    vendor: str = "massive"

    # event def (for mining / scoring)
    fwd_days: int = 5
    k_sigma: float = 1.5
    sigma_lookback: int = 60

    # rules mining
    rules_try: int = 6000
    rules_keep: int = 800
    min_support: int = 200
    min_event_hits: int = 30

    # permutation-ish gate proxy (simple)
    gate: bool = True
    gate_margin: float = 0.15  # extra above perm_p95

    # OOS filters
    oos_min_support: int = 200
    oos_min_lift: float = 1.35

    # runtime
    runtime_topn_long: int = 40

    # portfolio sim
    hold_days: int = 5
    max_pos: int = 3
    tc_bps_in: float = 4.0
    tc_bps_out: float = 4.0

    # concentration caps (symbol)
    cooldown_days: int = 0
    max_entries_per_symbol: int = 9999

    # cluster caps (library selection)
    cap_vol: int = 20
    cap_mom: int = 15
    cap_trend: int = 16
    cap_other: int = 40
    cap_pair: int = 5

    # rolling signature health (NO LOOKAHEAD)
    health_days: int = 60
    health_min_n: int = 80
    es5_floor: float = -0.12
    retire_on_median_leq0: bool = True
    retire_on_es5: bool = True

    # time-slice report
    slice_folds_only: bool = True   # True => only Fold2 by default
    slices: int = 3

    # misc
    seed: int = 7


def load_config() -> Config:
    dataset_root = Path(_env_str("DATASET_ROOT", str(Path("data") / "raw" / "massive_dataset")))
    start = _env_str("START", "2023-01-01")
    end = _env_str("END", "2026-02-28")

    cfg = Config(
        dataset_root=dataset_root,
        start=start,
        end=end,
        fwd_days=_env_int("FWD_DAYS", 5),
        k_sigma=_env_float("K_SIGMA", 1.5),
        sigma_lookback=_env_int("SIGMA_LOOKBACK", 60),
        rules_try=_env_int("RULES_TRY", 6000),
        rules_keep=_env_int("RULES_KEEP", 800),
        min_support=_env_int("MIN_SUPPORT", 200),
        min_event_hits=_env_int("MIN_EVENT_HITS", 30),
        gate=_env_bool("GATE", True),
        gate_margin=_env_float("GATE_MARGIN", 0.15),
        oos_min_support=_env_int("OOS_MIN_SUPPORT", 200),
        oos_min_lift=_env_float("OOS_MIN_LIFT", 1.35),
        runtime_topn_long=_env_int("RUNTIME_TOPN_LONG", 40),
        hold_days=_env_int("HOLD_DAYS", 5),
        max_pos=_env_int("MAX_POS", 3),
        tc_bps_in=_env_float("TC_BPS_IN", 4.0),
        tc_bps_out=_env_float("TC_BPS_OUT", 4.0),
        cooldown_days=_env_int("COOLDOWN_DAYS", 0),
        max_entries_per_symbol=_env_int("MAX_ENTRIES_PER_SYMBOL", 9999),
        cap_vol=_env_int("CAP_VOL", 20),
        cap_mom=_env_int("CAP_MOM", 15),
        cap_trend=_env_int("CAP_TREND", 16),
        cap_other=_env_int("CAP_OTHER", 40),
        cap_pair=_env_int("CAP_PAIR", 5),
        health_days=_env_int("HEALTH_DAYS", 60),
        health_min_n=_env_int("HEALTH_MIN_N", 80),
        es5_floor=_env_float("ES5_FLOOR", -0.12),
        retire_on_median_leq0=_env_bool("RETIRE_MEDIAN", True),
        retire_on_es5=_env_bool("RETIRE_ES5", True),
        slice_folds_only=_env_bool("SLICE_FOLD2_ONLY", True),
        slices=_env_int("SLICES", 3),
        seed=_env_int("SEED", 7),
    )
    return cfg


# ----------------------------- Data ingest -----------------------------

def _parse_yyyy_mm_dd(s: str) -> date:
    y, m, d = [int(x) for x in s.split("-")]
    return date(y, m, d)


def _date_to_str(d: date) -> str:
    return d.isoformat()


def _in_range(d: date, a: date, b: date) -> bool:
    return (d >= a) and (d <= b)


def _read_json(path: Path) -> Any:
    with path.open("r", encoding="utf-8") as f:
        return json.load(f)


def load_daily_aggs(dataset_root: Path, start: str, end: str) -> pd.DataFrame:
    """
    Expects: dataset_root/<TICKER>/aggs_1d_<start>_<end>.json
    Supports any filename starting with 'aggs_1d_' (we'll pick the largest 'results' file per ticker).
    """
    a = _parse_yyyy_mm_dd(start)
    b = _parse_yyyy_mm_dd(end)

    rows: List[Dict[str, Any]] = []
    tick_dirs = [p for p in dataset_root.iterdir() if p.is_dir()]
    tick_dirs.sort(key=lambda p: p.name.upper())

    for tdir in tick_dirs:
        ticker = tdir.name.upper()
        candidates = sorted(tdir.glob("aggs_1d_*.json"))
        if not candidates:
            continue

        best = None
        best_n = -1
        for p in candidates:
            try:
                js = _read_json(p)
                n = len(js.get("results") or [])
                if n > best_n:
                    best_n = n
                    best = p
            except Exception:
                continue
        if not best:
            continue

        js = _read_json(best)
        res = js.get("results") or []
        for r in res:
            # Polygon/Massive aggs: t (ms epoch), o h l c v
            # Use UTC date from epoch ms.
            ts_ms = r.get("t")
            if ts_ms is None:
                continue
            dt = datetime.fromtimestamp(ts_ms / 1000.0, tz=timezone.utc).date()
            if not _in_range(dt, a, b):
                continue
            rows.append({
                "date": _date_to_str(dt),
                "symbol": ticker,
                "o": float(r.get("o", float("nan"))),
                "h": float(r.get("h", float("nan"))),
                "l": float(r.get("l", float("nan"))),
                "c": float(r.get("c", float("nan"))),
                "v": float(r.get("v", float("nan"))),
            })

    df = pd.DataFrame(rows)
    if df.empty:
        raise RuntimeError(f"No daily aggs found under {dataset_root}")
    df = df.dropna(subset=["c"]).copy()
    df["date"] = pd.to_datetime(df["date"])
    df = df.sort_values(["date", "symbol"]).reset_index(drop=True)
    return df


# ----------------------------- Features -----------------------------

def _ema(series: pd.Series, span: int) -> pd.Series:
    return series.ewm(span=span, adjust=False).mean()


def build_features(df: pd.DataFrame) -> pd.DataFrame:
    """
    Per-symbol features, then cross-sectional quantiles by date.
    """
    out = df.copy()
    out["ret_1d"] = out.groupby("symbol")["c"].pct_change()
    out["logret_1d"] = (1.0 + out["ret_1d"]).apply(lambda x: math.log(x) if pd.notna(x) and x > 0 else float("nan"))

    # realized vol (10d)
    out["rv_10"] = out.groupby("symbol")["logret_1d"].rolling(10).std().reset_index(level=0, drop=True)

    # ATR proxy (14d) on daily
    high = out["h"]
    low = out["l"]
    close = out["c"]
    prev_close = out.groupby("symbol")["c"].shift(1)
    tr = pd.concat([
        (high - low).abs(),
        (high - prev_close).abs(),
        (low - prev_close).abs(),
    ], axis=1).max(axis=1)
    out["atr_14"] = tr.groupby(out["symbol"]).rolling(14).mean().reset_index(level=0, drop=True)
    out["atr_pct"] = out["atr_14"] / out["c"]

    # compression proxy: range / atr
    out["range_pct"] = (out["h"] - out["l"]) / out["c"]
    out["compression"] = (out["range_pct"] / (out["atr_pct"] + 1e-12))

    # momentum
    out["mom_1d"] = out.groupby("symbol")["c"].pct_change(1)
    out["mom_3d"] = out.groupby("symbol")["c"].pct_change(3)

    # trend / ema distances
    out["ema_fast"] = out.groupby("symbol")["c"].transform(lambda s: _ema(s, 10))
    out["ema_slow"] = out.groupby("symbol")["c"].transform(lambda s: _ema(s, 30))
    out["ema_dist"] = (out["c"] - out["ema_slow"]) / out["ema_slow"]
    out["ema_fast_slope"] = out.groupby("symbol")["ema_fast"].pct_change(3)
    out["ema_slow_slope"] = out.groupby("symbol")["ema_slow"].pct_change(5)

    # forward return for scoring / evaluation (close-to-close)
    out["fwd_ret"] = out.groupby("symbol")["c"].pct_change(-5) * -1.0  # placeholder
    # correct: pct_change(-N) gives (c_t / c_{t+N} - 1), so invert:
    # fwd = c_{t+N}/c_t - 1
    for n in [5]:
        fwd = out.groupby("symbol")["c"].shift(-n) / out["c"] - 1.0
        out[f"fwd_{n}d"] = fwd

    # drop rows missing core feats
    core = ["atr_pct", "rv_10", "compression", "mom_1d", "mom_3d", "ema_dist", "ema_fast_slope", "ema_slow_slope", "fwd_5d"]
    out = out.dropna(subset=core).copy()

    # cross-sectional quantiles by date
    def add_q(name: str, qs: Tuple[float, float, float]) -> None:
        q20, q50, q80 = qs
        g = out.groupby("date")[name]
        out[f"{name}_q20"] = g.transform(lambda s: s.quantile(q20))
        out[f"{name}_q50"] = g.transform(lambda s: s.quantile(q50))
        out[f"{name}_q80"] = g.transform(lambda s: s.quantile(q80))

    for col in ["atr_pct", "rv_10", "compression", "mom_1d", "mom_3d", "ema_dist", "ema_fast_slope", "ema_slow_slope"]:
        add_q(col, (0.20, 0.50, 0.80))

    return out


# ----------------------------- Signatures (rules) -----------------------------

# We’ll use a constrained signature space similar to what your logs show:
# long|atr_pct>q80|rv_10>q80 etc.
# That’s deliberate: less leakage risk, more interpretable, easier to control.

def _cond_gt(col: str, q: str) -> Tuple[str, Any]:
    return (f"{col}>{q}", lambda r: r[col] > r[f"{col}_{q}"])


def _cond_lt(col: str, q: str) -> Tuple[str, Any]:
    return (f"{col}<{q}", lambda r: r[col] < r[f"{col}_{q}"])


def build_signature_space() -> List[Tuple[str, List[Tuple[str, Any]]]]:
    Q20 = "q20"
    Q50 = "q50"
    Q80 = "q80"

    conds = []
    # VOL-ish
    conds.append(_cond_gt("atr_pct", Q50))
    conds.append(_cond_gt("atr_pct", Q80))
    conds.append(_cond_gt("rv_10", Q50))
    conds.append(_cond_gt("rv_10", Q80))
    # compression
    conds.append(_cond_gt("compression", Q50))
    conds.append(_cond_lt("compression", Q20))
    # momentum
    conds.append(_cond_lt("mom_1d", Q20))
    conds.append(_cond_lt("mom_1d", Q50))
    conds.append(_cond_lt("mom_3d", Q20))
    conds.append(_cond_lt("mom_3d", Q50))
    # trend / distance
    conds.append(_cond_lt("ema_dist", Q50))
    conds.append(_cond_gt("ema_dist", Q80))
    conds.append(_cond_lt("ema_fast_slope", Q50))
    conds.append(_cond_lt("ema_slow_slope", Q50))
    conds.append(_cond_gt("ema_slow_slope", Q50))

    # Make pairwise / triple combos (2–3 conditions) for long direction
    # Keep manageable: hand-picked patterns that match your observed top signatures.
    patterns: List[List[str]] = [
        ["atr_pct>q80", "rv_10>q80"],
        ["atr_pct>q80", "rv_10>q50"],
        ["atr_pct>q50", "rv_10>q80"],
        ["compression>q50", "rv_10>q80"],
        ["atr_pct>q50", "mom_1d<q20"],
        ["atr_pct>q50", "ema_dist<q50"],
        ["atr_pct>q50", "mom_3d<q50"],
        ["mom_3d<q20", "rv_10>q50"],
        ["atr_pct>q50", "ema_fast_slope<q50", "ema_slow_slope<q50"],
        ["atr_pct>q50", "mom_1d<q50"],
    ]

    # Build resolver from cond list
    cond_map = {name: fn for (name, fn) in conds}

    sigs: List[Tuple[str, List[Tuple[str, Any]]]] = []
    for pat in patterns:
        parts = []
        for p in pat:
            if p not in cond_map:
                continue
            parts.append((p, cond_map[p]))
        if len(parts) >= 2:
            sig = "long|" + "|".join([p for (p, _) in parts])
            sigs.append((sig, parts))

    # Add some extra 2-cond mixes to expand space a bit
    extras = [
        ("long|atr_pct>q50|rv_10>q50", ["atr_pct>q50", "rv_10>q50"]),
        ("long|atr_pct>q50|rv_10>q80", ["atr_pct>q50", "rv_10>q80"]),
        ("long|compression>q50|mom_1d<q50", ["compression>q50", "mom_1d<q50"]),
    ]
    for sig, pat in extras:
        parts = [(p, cond_map[p]) for p in pat if p in cond_map]
        if len(parts) >= 2:
            sigs.append((sig, parts))

    # Dedup
    seen = set()
    out = []
    for s, parts in sigs:
        if s in seen:
            continue
        seen.add(s)
        out.append((s, parts))
    return out


def eval_signature(df: pd.DataFrame, parts: List[Tuple[str, Any]]) -> pd.Series:
    # Row-wise apply is slow; use vectorized comparisons via df columns and q columns.
    mask = pd.Series(True, index=df.index)
    for name, _fn in parts:
        # Parse: "col>q80" or "col<q20"
        if ">" in name:
            col, q = name.split(">")
            mask &= df[col] > df[f"{col}_{q}"]
        elif "<" in name:
            col, q = name.split("<")
            mask &= df[col] < df[f"{col}_{q}"]
        else:
            raise ValueError(f"Bad condition: {name}")
    return mask


# ----------------------------- Metrics -----------------------------

def _es5(x: List[float]) -> float:
    if not x:
        return float("nan")
    xs = sorted(x)
    k = max(1, int(math.floor(0.05 * len(xs))))
    return float(sum(xs[:k]) / k)


def _median(x: List[float]) -> float:
    if not x:
        return float("nan")
    xs = sorted(x)
    n = len(xs)
    mid = n // 2
    if n % 2 == 1:
        return float(xs[mid])
    return float(0.5 * (xs[mid - 1] + xs[mid]))


def _p_gt0(x: List[float]) -> float:
    if not x:
        return float("nan")
    return float(sum(1 for v in x if v > 0.0) / len(x))


# ----------------------------- Folds -----------------------------

@dataclass(frozen=True)
class Fold:
    idx: int
    train_start: pd.Timestamp
    train_end: pd.Timestamp
    test_start: pd.Timestamp
    test_end: pd.Timestamp


def build_folds(dates: List[pd.Timestamp]) -> List[Fold]:
    # Fixed 3 folds similar to your logs (simple expanding-ish template)
    # We’ll compute boundaries by index proportions.
    ds = sorted(pd.to_datetime(dates).unique().tolist())
    if len(ds) < 300:
        raise RuntimeError("Not enough dates for folds")

    def pick(i: int) -> pd.Timestamp:
        i = max(0, min(i, len(ds) - 1))
        return ds[i]

    # approximate your windows by positions
    # Fold 1 test ~ last 90d in first segment, etc.
    # You can later replace with your exact dates if desired.
    # Here we mimic your printed fold windows:
    f1 = Fold(1, pd.Timestamp("2023-02-01"), pd.Timestamp("2024-10-02"), pd.Timestamp("2024-10-17"), pd.Timestamp("2025-02-27"))
    f2 = Fold(2, pd.Timestamp("2023-06-12"), pd.Timestamp("2025-02-12"), pd.Timestamp("2025-02-28"), pd.Timestamp("2025-07-09"))
    f3 = Fold(3, pd.Timestamp("2023-10-19"), pd.Timestamp("2025-06-24"), pd.Timestamp("2025-07-10"), pd.Timestamp("2025-11-13"))
    return [f1, f2, f3]


# ----------------------------- Library selection / clustering -----------------------------

def cluster_of_signature(sig: str) -> str:
    # Simple heuristic mapping used for caps
    # sig looks like "long|atr_pct>q80|rv_10>q80"
    s = sig.lower()
    if "atr_pct" in s or "rv_10" in s:
        # pair bucket
        if ("atr_pct" in s) and ("rv_10" in s):
            return "PAIR"
        return "VOL"
    if "mom_" in s:
        return "MOM"
    if "ema_" in s:
        return "TREND"
    if "compression" in s:
        return "VOL"
    return "OTHER"


def apply_cluster_caps(
    ranked: List[Tuple[str, float]],
    caps: Dict[str, int],
    want_n: int,
) -> Tuple[List[Tuple[str, float]], Dict[str, int]]:
    kept: List[Tuple[str, float]] = []
    used = defaultdict(int)
    skipped = 0
    for sig, w in ranked:
        c = cluster_of_signature(sig)
        cap = caps.get(c, 10**9)
        if used[c] >= cap:
            skipped += 1
            continue
        kept.append((sig, w))
        used[c] += 1
        if len(kept) >= want_n:
            break
    used["SKIP"] = skipped
    return kept, dict(used)


# ----------------------------- Rolling health (no look-ahead) -----------------------------

class RollingHealth:
    """
    For each signature, we add outcomes only when they mature (t + fwd_days).
    Health window is based on maturity date, last HEALTH_DAYS calendar trading days (by date index).
    """

    def __init__(self, health_days: int, min_n: int, es5_floor: float, retire_med: bool, retire_es5: bool):
        self.health_days = int(health_days)
        self.min_n = int(min_n)
        self.es5_floor = float(es5_floor)
        self.retire_med = bool(retire_med)
        self.retire_es5 = bool(retire_es5)

        # maturity_date -> list of (sig, outcome)
        self.pending: Dict[pd.Timestamp, List[Tuple[str, float]]] = defaultdict(list)

        # sig -> deque of (maturity_date, outcome)
        self.hist: Dict[str, deque] = defaultdict(lambda: deque())

        # sig -> retired?
        self.retired: Dict[str, bool] = defaultdict(bool)

        # counters
        self.retire_cnt_median = 0
        self.retire_cnt_es5 = 0
        self.retire_cnt_min_n = 0

    def schedule_outcome(self, sig: str, signal_date: pd.Timestamp, outcome: float, fwd_days: int) -> None:
        maturity = pd.Timestamp(signal_date) + pd.Timedelta(days=int(fwd_days))
        self.pending[maturity].append((sig, float(outcome)))

    def on_day(self, today: pd.Timestamp) -> None:
        # release matured outcomes
        items = self.pending.pop(pd.Timestamp(today), [])
        for sig, outc in items:
            self.hist[sig].append((pd.Timestamp(today), float(outc)))

        # prune history older than window
        cutoff = pd.Timestamp(today) - pd.Timedelta(days=int(self.health_days) * 2)
        for sig, dq in self.hist.items():
            while dq and dq[0][0] < cutoff:
                dq.popleft()

    def health_stats(self, sig: str, today: pd.Timestamp) -> Tuple[int, float, float]:
        # compute within last HEALTH_DAYS based on maturity date
        cutoff = pd.Timestamp(today) - pd.Timedelta(days=int(self.health_days))
        xs = [v for (d, v) in self.hist.get(sig, []) if d >= cutoff]
        n = len(xs)
        if n == 0:
            return 0, float("nan"), float("nan")
        return n, _median(xs), _es5(xs)

    def is_ok(self, sig: str, today: pd.Timestamp) -> bool:
        if self.retired.get(sig, False):
            return False
        n, med, es5 = self.health_stats(sig, today)
        if n < self.min_n:
            # insufficient evidence; do NOT retire, but treat as OK (conservative could be opposite)
            self.retire_cnt_min_n += 1
            return True
        if self.retire_med and (not math.isnan(med)) and (med <= 0.0):
            self.retired[sig] = True
            self.retire_cnt_median += 1
            return False
        if self.retire_es5 and (not math.isnan(es5)) and (es5 < self.es5_floor):
            self.retired[sig] = True
            self.retire_cnt_es5 += 1
            return False
        return True


# ----------------------------- Mining / scoring -----------------------------

@dataclass
class SigStats:
    sig: str
    support: int
    hits: int
    prec: float
    lift: float
    mean: float
    med: float
    pgt0: float
    es5: float


def compute_base_rate(train_df: pd.DataFrame, k_sigma: float, sigma_lookback: int, fwd_days: int) -> Tuple[float, float]:
    # Define "event up": fwd_5d > k_sigma * rolling_sigma
    # Rolling sigma computed per symbol on ret_1d
    x = train_df.copy()
    x["sigma"] = x.groupby("symbol")["ret_1d"].rolling(sigma_lookback).std().reset_index(level=0, drop=True)
    x = x.dropna(subset=["sigma", f"fwd_{fwd_days}d"])
    thr = k_sigma * x["sigma"]
    up = (x[f"fwd_{fwd_days}d"] > thr).astype(int)
    dn = (x[f"fwd_{fwd_days}d"] < -thr).astype(int)
    return float(up.mean()), float(dn.mean())


def eval_sig_stats(df: pd.DataFrame, sig: str, parts: List[Tuple[str, Any]], base_rate_up: float, k_sigma: float, sigma_lookback: int, fwd_days: int) -> Optional[SigStats]:
    x = df.copy()
    x["sigma"] = x.groupby("symbol")["ret_1d"].rolling(sigma_lookback).std().reset_index(level=0, drop=True)
    x = x.dropna(subset=["sigma", f"fwd_{fwd_days}d"])
    if x.empty:
        return None

    mask = eval_signature(x, parts)
    supp = int(mask.sum())
    if supp <= 0:
        return None

    thr = k_sigma * x["sigma"]
    hits = int(((x[f"fwd_{fwd_days}d"] > thr) & mask).sum())
    prec = float(hits / supp) if supp > 0 else 0.0
    lift = float(prec / (base_rate_up + 1e-12))

    rets = x.loc[mask, f"fwd_{fwd_days}d"].astype(float).tolist()
    if not rets:
        return None
    mean = float(sum(rets) / len(rets))
    med = _median(rets)
    pgt0 = _p_gt0(rets)
    es5 = _es5(rets)

    return SigStats(sig=sig, support=supp, hits=hits, prec=prec, lift=lift, mean=mean, med=med, pgt0=pgt0, es5=es5)


# ----------------------------- Time-slice report -----------------------------

def time_slice_report(oos_df: pd.DataFrame, sig_defs: Dict[str, List[Tuple[str, Any]]], fwd_days: int, slices: int, title: str) -> None:
    ds = sorted(oos_df["date"].unique().tolist())
    if len(ds) < slices * 5:
        _log(f"[SLICE] {title}: not enough dates for slicing (n_dates={len(ds)})")
        return

    # equal chunks by date count
    chunks: List[List[pd.Timestamp]] = []
    n = len(ds)
    step = n // slices
    for i in range(slices):
        a = i * step
        b = (i + 1) * step if i < slices - 1 else n
        chunks.append(ds[a:b])

    print("\n" + "=" * 80)
    print(f"[SLICE] {title}  slices={slices}  dates={len(ds)}")
    for i, ch in enumerate(chunks, 1):
        d0 = pd.Timestamp(ch[0]).date().isoformat()
        d1 = pd.Timestamp(ch[-1]).date().isoformat()
        print(f"[SLICE {i}] {d0}..{d1} (n_dates={len(ch)})")

        sub = oos_df[oos_df["date"].isin(ch)].copy()
        # Evaluate each signature distribution in this slice
        stats = []
        for sig, parts in sig_defs.items():
            m = eval_signature(sub, parts)
            xs = sub.loc[m, f"fwd_{fwd_days}d"].astype(float).tolist()
            if len(xs) < 50:
                continue
            stats.append((sig, len(xs), float(sum(xs)/len(xs)), _median(xs), _p_gt0(xs), _es5(xs)))

        stats.sort(key=lambda t: t[2])  # mean
        worst = stats[:10]
        best = stats[-10:][::-1]

        print(f"[SLICE {i}] WORST 10 by mean:")
        for sig, nobs, mean, med, pgt0, es5 in worst:
            print(f"  {sig}  n={nobs:4d} mean={mean:+.4f} med={med:+.4f} p>0={pgt0*100:5.1f}% es5={es5:+.4f}")

        print(f"[SLICE {i}] BEST 10 by mean:")
        for sig, nobs, mean, med, pgt0, es5 in best:
            print(f"  {sig}  n={nobs:4d} mean={mean:+.4f} med={med:+.4f} p>0={pgt0*100:5.1f}% es5={es5:+.4f}")


# ----------------------------- Portfolio sim -----------------------------

def simulate_fold(
    oos_df: pd.DataFrame,
    runtime_sigs: List[Tuple[str, float]],
    sig_defs: Dict[str, List[Tuple[str, Any]]],
    cfg: Config,
    fold_name: str,
) -> None:
    # Prepare daily universe
    oos_df = oos_df.sort_values(["date", "symbol"]).reset_index(drop=True)

    # Precompute signature masks and per-row score
    # Score = sum(weights of signatures that fire)
    score = pd.Series(0.0, index=oos_df.index)
    fires_total = 0
    for sig, w in runtime_sigs:
        parts = sig_defs[sig]
        m = eval_signature(oos_df, parts)
        fires = int(m.sum())
        fires_total += fires
        score.loc[m] += float(w)

    oos_df["score"] = score

    scored_rows = int((oos_df["score"] > 0.0).sum())
    print("\n" + "=" * 80)
    print(f"[SIM/{fold_name}] rows={len(oos_df)} scored_rows(score>0)={scored_rows}/{len(oos_df)} fires_total={fires_total}")

    # Coverage per day
    by_day = oos_df.groupby("date").apply(lambda g: float((g["score"] > 0).mean())).reset_index(name="coverage")
    cov_mean = float(by_day["coverage"].mean())
    cov_p10 = float(by_day["coverage"].quantile(0.10))
    cov_p90 = float(by_day["coverage"].quantile(0.90))
    print(f"[SIM/{fold_name}] coverage per-day: mean={cov_mean*100:.2f}% p10={cov_p10*100:.2f}% p90={cov_p90*100:.2f}%")

    # Rolling health tracker
    health = RollingHealth(
        health_days=cfg.health_days,
        min_n=cfg.health_min_n,
        es5_floor=cfg.es5_floor,
        retire_med=cfg.retire_on_median_leq0,
        retire_es5=cfg.retire_on_es5,
    )

    # Portfolio state
    cash = 1.0
    equity = 1.0
    positions: Dict[str, Dict[str, Any]] = {}  # sym -> {"entry_date", "entry_px", "shares", "exit_date"}
    last_entry_day_by_sym: Dict[str, pd.Timestamp] = {}
    entries_by_sym: Dict[str, int] = defaultdict(int)

    # For equity curve daily
    eq_curve: List[Tuple[pd.Timestamp, float]] = []

    # Debug counters
    open_fail_days = 0
    no_candidate_days = 0
    cand_missing_px_skips = 0
    cash_low_days = 0

    # Fees
    tc_paid = 0.0
    entries = 0
    exits = 0

    # Pre-index: day -> rows
    days = sorted(oos_df["date"].unique().tolist())
    day_rows = {d: oos_df[oos_df["date"] == d].copy() for d in days}

    # Trade loop (close-to-close, rebalance daily)
    for d in days:
        today = pd.Timestamp(d)

        # Mature health outcomes for today (no lookahead)
        health.on_day(today)

        # 1) mark-to-market equity at close
        day_df = day_rows[today]
        px = dict(zip(day_df["symbol"], day_df["c"]))
        # Compute current equity = cash + sum(shares*px)
        pos_val = 0.0
        for sym, pos in positions.items():
            p = px.get(sym)
            if p is None or not (p > 0.0):
                continue
            pos_val += float(pos["shares"]) * float(p)
        equity = float(cash + pos_val)
        eq_curve.append((today, equity))

        # 2) exits: time-based hold
        to_close = []
        for sym, pos in positions.items():
            ed = pd.Timestamp(pos["entry_date"])
            if (today - ed).days >= cfg.hold_days:
                to_close.append(sym)

        for sym in to_close:
            p = px.get(sym)
            if p is None or not (p > 0.0):
                continue
            sh = float(positions[sym]["shares"])
            gross = sh * float(p)
            fee = gross * (cfg.tc_bps_out / 10000.0)
            tc_paid += fee
            cash += (gross - fee)
            exits += 1
            del positions[sym]

        # 3) decide opens based on today scores, excluding retired signatures (rolling health)
        # We implement this by recomputing effective score per row:
        # score_eff = sum(w for sig fire if sig health ok today)
        candidates = day_df[day_df["score"] > 0.0].copy()
        if candidates.empty:
            no_candidate_days += 1
            continue

        # For each candidate row compute effective score via sig list with health filter.
        # This is heavier, but universe is small (29).
        eff_scores = []
        for idx, row in candidates.iterrows():
            sym = row["symbol"]
            s_eff = 0.0
            for sig, w in runtime_sigs:
                if not health.is_ok(sig, today):
                    continue
                parts = sig_defs[sig]
                ok = True
                for name, _fn in parts:
                    if ">" in name:
                        col, q = name.split(">")
                        if not (row[col] > row[f"{col}_{q}"]):
                            ok = False
                            break
                    else:
                        col, q = name.split("<")
                        if not (row[col] < row[f"{col}_{q}"]):
                            ok = False
                            break
                if ok:
                    s_eff += float(w)
            eff_scores.append((idx, s_eff))
        eff_map = dict(eff_scores)
        candidates["score_eff"] = candidates.index.map(lambda i: eff_map.get(i, 0.0))
        candidates = candidates[candidates["score_eff"] > 0.0].copy()
        if candidates.empty:
            # all candidates rely on retired sigs
            no_candidate_days += 1
            continue

        # rank by score_eff desc
        candidates = candidates.sort_values(["score_eff", "symbol"], ascending=[False, True])

        # open up to max_pos
        slots = cfg.max_pos - len(positions)
        if slots <= 0:
            continue

        # equal-weight allocation among NEW positions only (simple)
        # We use available cash only (no leverage). If you later want "infinite cash", that implies leverage,
        # which needs margin model; we keep it realistic.
        # Cash floor/clamp will be applied (later you said two fixes simultaneously; we keep stable now).
        alloc_per = cash / float(slots) if slots > 0 else 0.0
        if alloc_per <= 0.0:
            cash_low_days += 1
            open_fail_days += 1
            continue

        opened_today = 0
        for _, r in candidates.iterrows():
            if opened_today >= slots:
                break
            sym = str(r["symbol"])
            if sym in positions:
                continue

            # concentration controls
            if cfg.cooldown_days > 0:
                last = last_entry_day_by_sym.get(sym)
                if last is not None and (today - last).days < cfg.cooldown_days:
                    continue
            if entries_by_sym[sym] >= cfg.max_entries_per_symbol:
                continue

            p = float(r["c"])
            if not (p > 0.0):
                cand_missing_px_skips += 1
                continue

            gross = min(alloc_per, cash)
            if gross <= 0.0:
                cash_low_days += 1
                break

            fee = gross * (cfg.tc_bps_in / 10000.0)
            net = gross - fee
            if net <= 0.0:
                cash_low_days += 1
                break

            shares = net / p
            cash -= gross
            tc_paid += fee
            positions[sym] = {"entry_date": today, "entry_px": p, "shares": shares}
            last_entry_day_by_sym[sym] = today
            entries_by_sym[sym] += 1
            entries += 1
            opened_today += 1

            # schedule outcomes for rolling health: for each signature that fired on this row,
            # schedule the fwd_5d outcome to mature at today+FWD_DAYS.
            outc = float(r[f"fwd_{cfg.fwd_days}d"])
            for sig, w in runtime_sigs:
                parts = sig_defs[sig]
                ok = True
                for name, _fn in parts:
                    if ">" in name:
                        col, q = name.split(">")
                        if not (float(r[col]) > float(r[f"{col}_{q}"])):
                            ok = False
                            break
                    else:
                        col, q = name.split("<")
                        if not (float(r[col]) < float(r[f"{col}_{q}"])):
                            ok = False
                            break
                if ok:
                    health.schedule_outcome(sig, today, outc, cfg.fwd_days)

        if opened_today == 0:
            open_fail_days += 1

    # Metrics
    eq = pd.Series([v for _, v in eq_curve], index=[d for d, _ in eq_curve])
    daily_ret = eq.pct_change().dropna()
    if len(daily_ret) > 2:
        mean_day = float(daily_ret.mean())
        sd_day = float(daily_ret.std(ddof=1))
        sharpe = (mean_day / (sd_day + 1e-12)) * math.sqrt(252.0)
    else:
        sharpe = float("nan")

    # MaxDD
    roll_max = eq.cummax()
    dd = (eq / roll_max - 1.0)
    maxdd = float(dd.min()) if len(dd) else 0.0

    # CAGR approx
    if len(eq) > 2:
        days_n = (eq.index[-1] - eq.index[0]).days
        years = max(1e-9, days_n / 365.25)
        cagr = float(eq.iloc[-1] ** (1.0 / years) - 1.0)
    else:
        cagr = float("nan")

    print(f"\n[SIM/{fold_name}] RESULTS (long-only, close-to-close)")
    print(f"[SIM/{fold_name}] equity_end={eq.iloc[-1]:.4f}  CAGR~={cagr*100:.2f}%  Sharpe~={sharpe:.2f}  MaxDD={maxdd*100:.2f}%")
    print(f"[SIM/{fold_name}] entries={entries} exits={exits} turnover(entries/day)={entries/ max(1,len(days)):.3f}  TC_paid={tc_paid:.4f}")
    print(f"[SIM/{fold_name}] avg_pos={cfg.max_pos - 0:.2f}/{cfg.max_pos} slot_fill={100.0*(1.0 - open_fail_days/max(1,len(days))):.2f}% "
          f"no_candidate_days={no_candidate_days}/{len(days)} open_fail_days={open_fail_days}/{len(days)}")
    print(f"[SIM/{fold_name}] QA cand_missing_px_skips={cand_missing_px_skips} cash_low_days={cash_low_days}/{len(days)}")
    print(f"[SIM/{fold_name}] DBG retire_counts: median={health.retire_cnt_median} es5={health.retire_cnt_es5} min_n_checks={health.retire_cnt_min_n}")


# ----------------------------- Main -----------------------------

def main() -> int:
    cfg = load_config()
    print(f"[CFG] vendor={cfg.vendor} dataset_root={cfg.dataset_root}")
    print(f"[CFG] start={cfg.start} end={cfg.end} universe=auto(from folders)")
    print(f"[CFG] event: fwd_days={cfg.fwd_days} k_sigma={cfg.k_sigma} sigma_lookback={cfg.sigma_lookback}")
    print(f"[CFG] rules: try={cfg.rules_try} keep={cfg.rules_keep} min_support={cfg.min_support} min_event_hits={cfg.min_event_hits}")
    print(f"[CFG] OOS filter: support>={cfg.oos_min_support} lift>={cfg.oos_min_lift}")
    print(f"[CFG] runtime_topn_long={cfg.runtime_topn_long}")
    print(f"[CFG] hold_days={cfg.hold_days} max_pos={cfg.max_pos} TC(in/out)={cfg.tc_bps_in}/{cfg.tc_bps_out} bps")
    print(f"[CFG] cluster caps: VOL={cfg.cap_vol} MOM={cfg.cap_mom} TREND={cfg.cap_trend} OTHER={cfg.cap_other} PAIR={cfg.cap_pair}")
    print(f"[CFG] rolling health: days={cfg.health_days} min_n={cfg.health_min_n} ES5_FLOOR={cfg.es5_floor} retire_median={cfg.retire_on_median_leq0} retire_es5={cfg.retire_on_es5}")
    print(f"[CFG] slices: slices={cfg.slices} fold2_only={cfg.slice_folds_only}")

    df0 = load_daily_aggs(cfg.dataset_root, cfg.start, cfg.end)
    df = build_features(df0)

    dates = sorted(df["date"].unique().tolist())
    symbols = sorted(df["symbol"].unique().tolist())
    print(f"[DATA] pooled rows={len(df)} dates={len(dates)} symbols={len(symbols)}")

    folds = build_folds(dates)

    # signature universe
    sig_space = build_signature_space()
    sig_defs = {sig: parts for sig, parts in sig_space}

    # Build per-fold library stats (OOS-filtered across folds), then global library fold_count>=2
    per_fold_pass: Dict[int, Dict[str, SigStats]] = {}
    base_rates = {}

    for fold in folds:
        train = df[(df["date"] >= fold.train_start) & (df["date"] <= fold.train_end)].copy()
        test = df[(df["date"] >= fold.test_start) & (df["date"] <= fold.test_end)].copy()
        print("\n" + "=" * 80)
        print(f"[LIB/FOLD {fold.idx}] train={fold.train_start.date()}..{fold.train_end.date()}  test={fold.test_start.date()}..{fold.test_end.date()}")

        br_up, br_dn = compute_base_rate(train, cfg.k_sigma, cfg.sigma_lookback, cfg.fwd_days)
        base_rates[fold.idx] = br_up
        # Evaluate all sigs on TRAIN to get a simple "perm_p95 proxy":
        train_lifts = []
        train_stats = {}
        for sig, parts in sig_space:
            st = eval_sig_stats(train, sig, parts, br_up, cfg.k_sigma, cfg.sigma_lookback, cfg.fwd_days)
            if st is None:
                continue
            train_stats[sig] = st
            if st.support >= cfg.min_support:
                train_lifts.append(st.lift)

        if not train_lifts:
            raise RuntimeError("No train lifts computed; check data")

        # gate threshold proxy: p95(train_lifts) + margin
        perm_p95 = float(pd.Series(train_lifts).quantile(0.95))
        gate_thr = perm_p95 + cfg.gate_margin if cfg.gate else -1e9

        # Pick top train rules by lift with support/hits filters
        cand_train = []
        for sig, st in train_stats.items():
            if st.support < cfg.min_support:
                continue
            if st.hits < cfg.min_event_hits:
                continue
            if st.lift < gate_thr:
                continue
            cand_train.append((sig, st.lift))
        cand_train.sort(key=lambda t: t[1], reverse=True)
        cand_train = cand_train[:cfg.rules_keep]

        print(f"[LIB/FOLD {fold.idx}] mined_rules={len(cand_train)} perm_p95={perm_p95:.3f}")

        # OOS evaluation for big rules
        passed = {}
        big_eval = 0
        for sig, _ in cand_train:
            st_oos = eval_sig_stats(test, sig, sig_defs[sig], br_up, cfg.k_sigma, cfg.sigma_lookback, cfg.fwd_days)
            if st_oos is None:
                continue
            big_eval += 1
            if st_oos.support >= cfg.oos_min_support and st_oos.lift >= cfg.oos_min_lift:
                passed[sig] = st_oos

        print(f"[LIB/FOLD {fold.idx}] OOS long big-eval={big_eval} pass(lift>={cfg.oos_min_lift})={len(passed)}")
        per_fold_pass[fold.idx] = passed

        # Time-slice only for fold2 by default
        if (not cfg.slice_folds_only) or (fold.idx == 2):
            time_slice_report(test, sig_defs, cfg.fwd_days, cfg.slices, title=f"Fold {fold.idx} OOS")

    # Global library fold_count>=2
    sig_fold_count = defaultdict(int)
    sig_agg: Dict[str, List[SigStats]] = defaultdict(list)

    for fi, mp in per_fold_pass.items():
        for sig, st in mp.items():
            sig_fold_count[sig] += 1
            sig_agg[sig].append(st)

    global_lib = []
    for sig, k in sig_fold_count.items():
        if k >= 2:
            # aggregate weight: average (lift-1) * mean / |es5| proxy (stability-ish)
            sts = sig_agg[sig]
            lift = float(sum(s.lift for s in sts) / len(sts))
            mean = float(sum(s.mean for s in sts) / len(sts))
            es5 = float(sum(s.es5 for s in sts) / len(sts))
            w = max(0.0, (lift - 1.0)) * max(0.0, mean) / (abs(es5) + 1e-6)
            global_lib.append((sig, w, lift, mean, es5, k))

    global_lib.sort(key=lambda t: t[1], reverse=True)
    library_size = len(global_lib)

    print("\n" + "=" * 80)
    print("[GLOBAL] Long Rule Library (OOS-filtered across folds)")
    print("[GLOBAL] Fold pass counts: " + " | ".join([f"F{f.idx}: {len(per_fold_pass[f.idx])}" for f in folds]))
    print(f"[GLOBAL] library_size={library_size} (long, fold_count>=2)")

    # Rank -> apply caps -> choose runtime_topn_long
    caps = {"VOL": cfg.cap_vol, "MOM": cfg.cap_mom, "TREND": cfg.cap_trend, "OTHER": cfg.cap_other, "PAIR": cfg.cap_pair}
    ranked = [(sig, w) for (sig, w, *_rest) in global_lib if w > 0.0]
    runtime_kept, used = apply_cluster_caps(ranked, caps, cfg.runtime_topn_long)
    print(f"[RUNTIME] selected signatures={len(runtime_kept)}/{cfg.runtime_topn_long} caps_used={used}")

    # Show top runtime sigs
    print("[RUNTIME] TOP 10 runtime signatures:")
    for i, (sig, w) in enumerate(runtime_kept[:10], 1):
        # find aggregated stats row
        row = next((t for t in global_lib if t[0] == sig), None)
        if row:
            _, _, lift, mean, es5, k = row
            print(f"  #{i:02d} folds={k} lift={lift:.2f} mean={mean:.4f} es5={es5:.4f} w={w:.4f}")
            print(f"       sig={sig}")
        else:
            print(f"  #{i:02d} w={w:.4f} sig={sig}")

    # Simulate each fold OOS
    for fold in folds:
        test = df[(df["date"] >= fold.test_start) & (df["date"] <= fold.test_end)].copy()
        simulate_fold(test, runtime_kept, sig_defs, cfg, fold_name=f"FOLD {fold.idx}")

    _log("[DONE] Ranker hold-sim MVP completed (with time-slice + rolling health retire).")
    return 0


if __name__ == "__main__":
    try:
        rc = main()
    except Exception:
        _log("[FATAL] unhandled exception")
        traceback.print_exc()
        rc = 1
    _press_enter_exit(int(rc))