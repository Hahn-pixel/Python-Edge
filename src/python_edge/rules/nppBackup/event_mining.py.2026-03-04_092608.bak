from __future__ import annotations

from dataclasses import dataclass
from typing import Dict, List, Optional, Tuple

import numpy as np
import pandas as pd


# =========================
# Dataclasses / Config
# =========================


@dataclass(frozen=True)
class EventMiningConfig:
    fwd_days: int = 5
    sigma_lookback: int = 60
    k_sigma: float = 1.5

    max_rules_try: int = 6000
    max_rules_keep: int = 800
    min_support: int = 200
    min_event_hits: int = 30
    max_conds: int = 3
    seed: int = 7

    perm_trials: int = 50
    perm_topk: int = 20
    perm_gate_enabled: bool = True
    perm_gate_margin: float = 0.15

    # Creative mining mix
    mix_random: float = 0.55
    mix_midband: float = 0.25
    mix_prototype: float = 0.20

    # Prototype mining
    proto_top_days: int = 180
    proto_rules: int = 800

    # Midband mining
    midband_prob: float = 0.65


@dataclass(frozen=True)
class Rule:
    rule_id: str
    direction: str  # "long" or "short"
    # Each cond is (feature, op, meta_key). meta_key like "mom_5d__q80".
    conds: List[Tuple[str, str, str]]
    # meta holds numeric thresholds keyed by meta_key.
    meta: Dict[str, float]


@dataclass(frozen=True)
class RuleStats:
    rule_id: str
    direction: str
    support: int
    event_hits: int
    base_rate: float
    precision: float
    lift: float
    mean_signed: float
    median_signed: float
    p_pos_signed: float
    es5_signed: float
    signature: str


# =========================
# Core metrics
# =========================


def _es5(x: np.ndarray) -> float:
    if x.size == 0:
        return float("nan")
    q = np.quantile(x, 0.05)
    tail = x[x <= q]
    return float(np.mean(tail)) if tail.size else float(q)


def _quantile_thresholds(s: pd.Series) -> Dict[str, float]:
    s2 = s.replace([np.inf, -np.inf], np.nan).dropna()
    if len(s2) == 0:
        return {"q20": 0.0, "q50": 0.0, "q80": 0.0}
    return {
        "q20": float(s2.quantile(0.2)),
        "q50": float(s2.quantile(0.5)),
        "q80": float(s2.quantile(0.8)),
    }


def label_events(df: pd.DataFrame, cfg: EventMiningConfig) -> pd.DataFrame:
    out = df.copy()
    sig = out["ret_1d"].rolling(cfg.sigma_lookback).std()
    thr = cfg.k_sigma * sig * np.sqrt(cfg.fwd_days)

    out["sigma_roll"] = sig
    out["event_thr"] = thr

    fwd = out[f"fwd_{cfg.fwd_days}d_ret"]
    out["event_up"] = (fwd > thr).astype("Int64")
    out["event_dn"] = (fwd < -thr).astype("Int64")
    return out


def _apply_rule_mask(df: pd.DataFrame, rule: Rule) -> pd.Series:
    mask = pd.Series(True, index=df.index)
    for feat, op, meta_key in rule.conds:
        thr = rule.meta[meta_key]
        if op == ">":
            mask &= (df[feat] > thr)
        elif op == "<":
            mask &= (df[feat] < thr)
        else:
            raise ValueError(f"Unsupported op: {op}")
    return mask


def _canonical_signature(direction: str, conds: List[Tuple[str, str, str]]) -> str:
    """Cross-fold comparable signature (uses quantile TAG, not numeric threshold)."""
    parts: List[str] = []
    for feat, op, meta_key in conds:
        tag = meta_key.split("__")[-1] if "__" in meta_key else meta_key
        parts.append(f"{feat}{op}{tag}")
    parts = sorted(parts)
    return direction + "|" + "|".join(parts)


def score_rule_event(df: pd.DataFrame, rule: Rule, event_col: str, fwd_col: str) -> Optional[RuleStats]:
    m = _apply_rule_mask(df, rule).to_numpy()
    support = int(np.sum(m))
    if support <= 0:
        return None

    ev = df[event_col].to_numpy(dtype=int)
    hits = int(np.sum(ev[m] == 1))
    base_rate = float(np.mean(ev == 1)) if ev.size else 0.0
    precision = float(hits / support) if support > 0 else 0.0
    lift = float(precision / base_rate) if base_rate > 0 else float("nan")

    fwd = df[fwd_col].to_numpy(dtype=float)
    signed = fwd if rule.direction == "long" else (-fwd)
    xs = signed[m]

    mean_s = float(np.mean(xs)) if xs.size else float("nan")
    med_s = float(np.median(xs)) if xs.size else float("nan")
    ppos = float(np.mean(xs > 0)) if xs.size else float("nan")
    es5 = _es5(xs.astype(float)) if xs.size else float("nan")

    sig = _canonical_signature(rule.direction, rule.conds)
    return RuleStats(
        rule_id=rule.rule_id,
        direction=rule.direction,
        support=support,
        event_hits=hits,
        base_rate=base_rate,
        precision=precision,
        lift=lift,
        mean_signed=mean_s,
        median_signed=med_s,
        p_pos_signed=ppos,
        es5_signed=es5,
        signature=sig,
    )


# =========================
# Candidate generation
# =========================


def _make_atomic_cond(
    rng: np.random.Generator,
    direction: str,
    feat: str,
    thrs: Dict[str, Dict[str, float]],
) -> Tuple[Tuple[str, str, str], Dict[str, float]]:
    if direction == "long":
        op = rng.choice([">", "<"], p=[0.65, 0.35])
        thr_name = rng.choice(["q80", "q50"] if op == ">" else ["q20", "q50"])
    else:
        op = rng.choice(["<", ">"], p=[0.65, 0.35])
        thr_name = rng.choice(["q20", "q50"] if op == "<" else ["q50", "q80"])

    meta_key = f"{feat}__{thr_name}"
    return (feat, op, meta_key), {meta_key: thrs[feat][thr_name]}


def _make_interval_conds(
    feat: str,
    lo_tag: str,
    hi_tag: str,
    thrs: Dict[str, Dict[str, float]],
) -> Tuple[List[Tuple[str, str, str]], Dict[str, float]]:
    mk_lo = f"{feat}__{lo_tag}"
    mk_hi = f"{feat}__{hi_tag}"
    conds = [(feat, ">", mk_lo), (feat, "<", mk_hi)]
    meta = {mk_lo: thrs[feat][lo_tag], mk_hi: thrs[feat][hi_tag]}
    return conds, meta


def _biased_feature_sample(rng: np.random.Generator, feature_cols: List[str], n: int) -> List[str]:
    feats = np.array(feature_cols, dtype=object)
    w = np.ones(len(feats), dtype=float)

    for i, f in enumerate(feats):
        fs = str(f)
        if ("d_" in fs) or ("_minus_" in fs) or ("_jump" in fs) or ("rel_" in fs) or ("is_" in fs):
            w[i] *= 2.2
        if ("compression" in fs) or ("atr_pct" in fs) or ("rv_" in fs):
            w[i] *= 1.2

    w = w / np.sum(w)
    pick = rng.choice(feats, size=n, replace=False, p=w)
    return [str(x) for x in pick]


def _gen_candidates_random(
    rng: np.random.Generator,
    cfg: EventMiningConfig,
    feature_cols: List[str],
    thrs: Dict[str, Dict[str, float]],
    start_k: int,
    count: int,
) -> List[Rule]:
    out: List[Rule] = []
    for i in range(count):
        k = start_k + i
        direction = "long" if (k % 2 == 0) else "short"

        n_conds = int(rng.choice([2, 3], p=[0.70, 0.30])) if cfg.max_conds >= 3 else 2
        feats = _biased_feature_sample(rng, feature_cols, n_conds)

        conds: List[Tuple[str, str, str]] = []
        meta: Dict[str, float] = {}
        for f in feats:
            c, m = _make_atomic_cond(rng, direction, f, thrs)
            conds.append(c)
            meta.update(m)

        rid = f"E{direction[0].upper()}R{k:05d}"
        out.append(Rule(rule_id=rid, direction=direction, conds=conds, meta=meta))
    return out


def _gen_candidates_midband(
    rng: np.random.Generator,
    cfg: EventMiningConfig,
    feature_cols: List[str],
    thrs: Dict[str, Dict[str, float]],
    start_k: int,
    count: int,
) -> List[Rule]:
    out: List[Rule] = []
    for i in range(count):
        k = start_k + i
        direction = "long" if (k % 2 == 0) else "short"

        f_interval = _biased_feature_sample(rng, feature_cols, 1)[0]
        use_interval = bool(rng.random() < cfg.midband_prob)

        conds: List[Tuple[str, str, str]] = []
        meta: Dict[str, float] = {}

        if use_interval:
            lo_tag, hi_tag = ("q20", "q50") if (rng.random() < 0.5) else ("q50", "q80")
            c2, m2 = _make_interval_conds(f_interval, lo_tag, hi_tag, thrs)
            conds.extend(c2)
            meta.update(m2)
        else:
            c, m = _make_atomic_cond(rng, direction, f_interval, thrs)
            conds.append(c)
            meta.update(m)

        f2 = _biased_feature_sample(rng, feature_cols, 1)[0]
        c3, m3 = _make_atomic_cond(rng, direction, f2, thrs)
        conds.append(c3)
        meta.update(m3)

        rid = f"E{direction[0].upper()}M{k:05d}"
        out.append(Rule(rule_id=rid, direction=direction, conds=conds, meta=meta))
    return out


def _proto_bucket(v: float, q20: float, q50: float, q80: float) -> str:
    if not np.isfinite(v):
        return "na"
    if v <= q20:
        return "q20"
    if v <= q50:
        return "q50"
    if v <= q80:
        return "q80"
    return "q80"


def _gen_candidates_prototype(
    rng: np.random.Generator,
    cfg: EventMiningConfig,
    df_train: pd.DataFrame,
    feature_cols: List[str],
    thrs: Dict[str, Dict[str, float]],
    start_k: int,
    count: int,
) -> List[Rule]:
    out: List[Rule] = []
    fwd_col = f"fwd_{cfg.fwd_days}d_ret"
    if fwd_col not in df_train.columns or df_train.empty:
        return out

    fwd = df_train[fwd_col].to_numpy(dtype=float)
    n_take = max(10, min(cfg.proto_top_days, fwd.size))
    idx_long = np.argsort(-fwd)[:n_take]
    idx_short = np.argsort(fwd)[:n_take]

    def build_proto(idxs: np.ndarray) -> List[Tuple[str, str, str]]:
        counts: Dict[Tuple[str, str], int] = {}
        for feat in feature_cols:
            qs = thrs[feat]
            a = df_train[feat].to_numpy(dtype=float)
            for j in idxs:
                tag = _proto_bucket(a[j], qs["q20"], qs["q50"], qs["q80"])
                if tag == "na":
                    continue
                counts[(feat, tag)] = counts.get((feat, tag), 0) + 1

        items = list(counts.items())
        items.sort(key=lambda kv: kv[1], reverse=True)

        picked: List[Tuple[str, str, str]] = []
        for (feat, tag), _n in items[:50]:
            op = ">" if tag in ("q50", "q80") else "<"
            meta_key = f"{feat}__{tag}"
            picked.append((feat, op, meta_key))
        return picked

    proto_long = build_proto(idx_long)
    proto_short = build_proto(idx_short)

    def make_rule(direction: str, proto: List[Tuple[str, str, str]], rid: str) -> Optional[Rule]:
        n_conds = int(rng.choice([2, 3], p=[0.75, 0.25])) if cfg.max_conds >= 3 else 2
        if len(proto) < n_conds:
            return None
        chosen = list(rng.choice(proto, size=n_conds, replace=False))

        conds: List[Tuple[str, str, str]] = []
        meta: Dict[str, float] = {}
        for feat, op, meta_key in chosen:
            tag = meta_key.split("__")[-1]
            meta[meta_key] = thrs[feat][tag]
            conds.append((feat, op, meta_key))

        # mutation: flip op OR nudge tag toward q50
        if conds and (rng.random() < 0.35):
            j = int(rng.integers(0, len(conds)))
            feat, op, meta_key = conds[j]
            tag = meta_key.split("__")[-1]
            if rng.random() < 0.5:
                op2 = "<" if op == ">" else ">"
                conds[j] = (feat, op2, meta_key)
            else:
                new_tag = "q50" if tag != "q50" else ("q20" if rng.random() < 0.5 else "q80")
                new_key = f"{feat}__{new_tag}"
                meta.pop(meta_key, None)
                meta[new_key] = thrs[feat][new_tag]
                conds[j] = (feat, op, new_key)

        return Rule(rule_id=rid, direction=direction, conds=conds, meta=meta)

    for i in range(count):
        k = start_k + i
        direction = "long" if (k % 2 == 0) else "short"
        proto = proto_long if direction == "long" else proto_short
        if not proto:
            continue
        rid = f"E{direction[0].upper()}P{k:05d}"
        r = make_rule(direction, proto, rid)
        if r is not None:
            out.append(r)

    return out


def _score_key(st: RuleStats) -> Tuple[float, float, int, float]:
    return (st.lift, st.precision, st.support, st.mean_signed)


# =========================
# Permutation sanity
# =========================


def _nan_p95(x: np.ndarray) -> float:
    x2 = x[np.isfinite(x)]
    if x2.size == 0:
        return float("nan")
    return float(np.quantile(x2, 0.95))


def _permutation_sanity(df_train: pd.DataFrame, rules: List[Rule], cfg: EventMiningConfig) -> Dict[str, float | str]:
    if not rules:
        return {
            "perm_trials": float(cfg.perm_trials),
            "perm_topk_mean": float("nan"),
            "perm_topk_p95": float("nan"),
            "perm_status": "unavailable",
            "perm_reason": "no_rules",
        }
    if cfg.perm_trials <= 0:
        return {
            "perm_trials": float(cfg.perm_trials),
            "perm_topk_mean": float("nan"),
            "perm_topk_p95": float("nan"),
            "perm_status": "unavailable",
            "perm_reason": "perm_trials<=0",
        }

    rng = np.random.default_rng(cfg.seed + 100)
    masks: Dict[str, np.ndarray] = {r.rule_id: _apply_rule_mask(df_train, r).to_numpy() for r in rules}

    ev_up = df_train["event_up"].to_numpy(dtype=int)
    ev_dn = df_train["event_dn"].to_numpy(dtype=int)

    lifts_topk: List[float] = []
    any_trial_has_lifts = False

    for _ in range(cfg.perm_trials):
        perm_up = ev_up.copy()
        perm_dn = ev_dn.copy()
        rng.shuffle(perm_up)
        rng.shuffle(perm_dn)

        base_up = float(np.mean(perm_up == 1)) if perm_up.size else 0.0
        base_dn = float(np.mean(perm_dn == 1)) if perm_dn.size else 0.0

        lifts: List[float] = []
        for r in rules:
            m = masks[r.rule_id]
            support = int(np.sum(m))
            if support < cfg.min_support:
                continue

            if r.direction == "long":
                if base_up <= 0:
                    continue
                hits = int(np.sum(perm_up[m] == 1))
                precision = float(hits / support)
                lift = float(precision / base_up)
            else:
                if base_dn <= 0:
                    continue
                hits = int(np.sum(perm_dn[m] == 1))
                precision = float(hits / support)
                lift = float(precision / base_dn)

            if np.isfinite(lift):
                lifts.append(lift)

        if lifts:
            any_trial_has_lifts = True
            lifts.sort(reverse=True)
            topk = lifts[: max(1, cfg.perm_topk)]
            lifts_topk.append(float(np.mean(topk)))
        else:
            lifts_topk.append(float("nan"))

    arr = np.array(lifts_topk, dtype=float)
    p95 = _nan_p95(arr)

    if (not any_trial_has_lifts) or (not np.isfinite(p95)):
        return {
            "perm_trials": float(cfg.perm_trials),
            "perm_topk_mean": float("nan"),
            "perm_topk_p95": float("nan"),
            "perm_status": "unavailable",
            "perm_reason": "all_nan_or_no_valid_lifts",
        }

    mean = float(np.nanmean(arr))
    return {
        "perm_trials": float(cfg.perm_trials),
        "perm_topk_mean": mean,
        "perm_topk_p95": float(p95),
        "perm_status": "ok",
        "perm_reason": "",
    }


# =========================
# Public API
# =========================


def mine_event_rules(
    df_train: pd.DataFrame,
    feature_cols: List[str],
    cfg: EventMiningConfig,
) -> Tuple[List[Rule], Dict[str, RuleStats], Dict[str, float | str]]:
    rng = np.random.default_rng(cfg.seed)

    thrs: Dict[str, Dict[str, float]] = {c: _quantile_thresholds(df_train[c]) for c in feature_cols}
    fwd_col = f"fwd_{cfg.fwd_days}d_ret"

    n_total = int(cfg.max_rules_try)
    n_rand = int(n_total * float(cfg.mix_random))
    n_mid = int(n_total * float(cfg.mix_midband))
    n_proto = max(0, n_total - n_rand - n_mid)

    candidates: List[Rule] = []
    candidates.extend(_gen_candidates_random(rng, cfg, feature_cols, thrs, start_k=0, count=n_rand))
    candidates.extend(_gen_candidates_midband(rng, cfg, feature_cols, thrs, start_k=n_rand, count=n_mid))

    if n_proto > 0 and cfg.proto_rules > 0:
        n_use = min(n_proto, int(cfg.proto_rules))
        candidates.extend(
            _gen_candidates_prototype(
                rng,
                cfg,
                df_train,
                feature_cols,
                thrs,
                start_k=n_rand + n_mid,
                count=n_use,
            )
        )

    best_by_sig: Dict[str, Tuple[Rule, RuleStats]] = {}
    for r in candidates:
        event_col = "event_up" if r.direction == "long" else "event_dn"
        st = score_rule_event(df_train, r, event_col=event_col, fwd_col=fwd_col)
        if st is None:
            continue
        if st.support < cfg.min_support:
            continue
        if st.event_hits < cfg.min_event_hits:
            continue
        if not np.isfinite(st.lift) or st.lift <= 1.05:
            continue
        if not np.isfinite(st.mean_signed) or st.mean_signed <= 0:
            continue

        cur = best_by_sig.get(st.signature)
        if cur is None:
            best_by_sig[st.signature] = (r, st)
        else:
            _, st0 = cur
            if _score_key(st) > _score_key(st0):
                best_by_sig[st.signature] = (r, st)

    rules = [v[0] for v in best_by_sig.values()]
    stats = {v[0].rule_id: v[1] for v in best_by_sig.values()}

    perm = _permutation_sanity(df_train, rules, cfg)
    perm_p95 = float(perm.get("perm_topk_p95", float("nan")))

    if cfg.perm_gate_enabled and np.isfinite(perm_p95):
        thr = perm_p95 + cfg.perm_gate_margin
        gated_rules: List[Rule] = []
        gated_stats: Dict[str, RuleStats] = {}
        for r in rules:
            st = stats[r.rule_id]
            if st.lift > thr:
                gated_rules.append(r)
                gated_stats[r.rule_id] = st
        rules, stats = gated_rules, gated_stats

    def rank_key(r: Rule) -> float:
        st = stats[r.rule_id]
        return (st.lift - 1.0) * 2.0 + st.precision * 1.0 + st.mean_signed * 5.0 + np.log1p(st.event_hits) * 0.2

    rules = sorted(rules, key=rank_key, reverse=True)[: cfg.max_rules_keep]
    stats = {r.rule_id: stats[r.rule_id] for r in rules}
    return rules, stats, perm


def evaluate_rules_oos(df_oos: pd.DataFrame, rules: List[Rule], cfg: EventMiningConfig) -> pd.DataFrame:
    if df_oos.empty or not rules:
        return pd.DataFrame()

    fwd_col = f"fwd_{cfg.fwd_days}d_ret"
    rows: List[Dict[str, object]] = []

    for r in rules:
        event_col = "event_up" if r.direction == "long" else "event_dn"
        st = score_rule_event(df_oos, r, event_col=event_col, fwd_col=fwd_col)
        if st is None:
            continue
        rows.append(
            {
                "rule_id": st.rule_id,
                "direction": st.direction,
                "signature": st.signature,
                "support": st.support,
                "event_hits": st.event_hits,
                "base_rate": st.base_rate,
                "precision": st.precision,
                "lift": st.lift,
                "mean_signed": st.mean_signed,
                "median_signed": st.median_signed,
                "p_pos_signed": st.p_pos_signed,
                "es5_signed": st.es5_signed,
            }
        )

    return pd.DataFrame(rows)
